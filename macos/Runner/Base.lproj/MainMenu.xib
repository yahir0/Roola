                            <menuItem title="拡大/縮小" id="zoomItem">
                                <modifierMask key="keyEquivalentModifierMask"/>
                                <connections>
                                    <action selector="performZoom:" target="-1" id="zoomAction"/>
                                </connections>
                            </menuItem>
                            <menuItem isSeparatorItem="YES" id="windowSep1"/>
                            <menuItem title="すべてを手前に移動" id="bringAllToFrontItem">
                                <modifierMask key="keyEquivalentModifierMask"/>
                                <connections>
                                    <action selector="arrangeInFront:" target="-1" id="bringAllToFrontAction"/>
                                </connections>
