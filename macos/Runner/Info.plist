<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIconFile</key>
	<string></string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleDisplayName</key>
	<string>Roola</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>
	<key>NSHumanReadableCopyright</key>
	<string>$(PRODUCT_COPYRIGHT)</string>
	<key>NSMainNibFile</key>
	<string>MainMenu</string>
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>
	<!-- AppKit / Cocoa が認識するサポート言語の宣言。Flutter 側の多言語化
	     (ARB) とは別レイヤで、ここに ja を入れないと Sparkle や標準
	     ダイアログが英語のままになる。Sparkle 2 は ja を含む多数の言語の
	     翻訳を framework 内に持っており、ここで宣言されていればシステム
	     ロケールに従って自動で当たる。 -->
	<key>CFBundleLocalizations</key>
	<array>
		<string>en</string>
		<string>ja</string>
	</array>
	<!-- Sparkle 自動更新 (docs/sparkle.md / ADR は無し)
	     SUFeedURL は gh-pages ブランチ + GitHub Pages で配信される appcast.xml
	     SUPublicEDKey は EdDSA 鍵ペアの公開鍵側。秘密鍵側は
	     SPARKLE_PRIVATE_KEY_BASE64 Secret として CI に登録済みで、
	     リリースワークフローが appcast.xml の各エントリを署名する。
	     SUEnableAutomaticChecks=true でアプリ起動時 + 24h 毎にチェックを走らせる -->
	<key>SUFeedURL</key>
	<string>https://yahir0.github.io/Roola/appcast.xml</string>
	<key>SUPublicEDKey</key>
	<string>EEFD65po9ggBgEW9Pg8jvHEXsBjOFdrrEzm2A9+imtM=</string>
	<key>SUEnableAutomaticChecks</key>
	<true/>
</dict>
</plist>
